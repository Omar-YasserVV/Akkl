  {
    "service": "svc-auth",
    "base_url": "/auth",
    "endpoints": [
      {
        "action": "Local Signup",
        "method": "POST",
        "url": "/auth/signup",
        "description": "Registers a new user and sets access/refresh tokens in cookies.",
        "body_schema": {
          "email": "string (Required: Valid email format, ex: omar@email.com)",
          "password": "string (Required: Min 8 chars)",
          "fullName": "string (Required, ex: Omar Yasser)",
          "username": "string (Required, ex: omar_user)",
          "phone": "string (Required: Valid phone format)",
          "image": "string (Optional: URL)",
          "role": "enum (Optional: CUSTOMER | BUSINESS_OWNER)"
        },
        "security": "None (public)"
      },
      {
        "action": "Local Login",
        "method": "POST",
        "url": "/auth/login",
        "description": "Authenticates user credentials and sets access/refresh tokens in cookies.",
        "body_schema": {
          "email": "string (Required, ex: omar@email.com)",
          "password": "string (Required)"
        },
        "security": "None (public)"
      },
      {
        "action": "Google Login",
        "method": "GET",
        "url": "/auth/google",
        "description": "Initializes the Google OAuth2 flow via Passport strategy."
      },
      {
        "action": "Google Callback",
        "method": "GET",
        "url": "/auth/google/callback",
        "description": "Handles Google redirection. Returns tempToken for new users or logs in existing users."
      },
      {
        "action": "Complete Google Signup",
        "method": "POST",
        "url": "/auth/complete-google-signup",
        "description": "Finalizes registration for Google users by requiring a password and phone number.",
        "body_schema": {
          "token": "string (Required: JWT from Google callback)",
          "password": "string (Required: Min 8 chars)",
          "passwordConfirmation": "string (Required: Must match password)",
          "phone": "string (Required: Valid phone format)",
          "username": "string (Optional)",
          "role": "enum (Optional: CUSTOMER | BUSINESS_OWNER)"
        }
      },
      {
        "action": "Forgot Password",
        "method": "POST",
        "url": "/auth/forgot-password",
        "description": "Generates a 6-digit OTP and sends it to the user's email via Nodemailer.",
        "body_schema": {
          "email": "string (Required)"
        }
      },
      {
        "action": "Reset Password",
        "method": "POST",
        "url": "/auth/reset-password",
        "description": "Verifies the email OTP and updates the user's password in the database.",
        "body_schema": {
          "email": "string (Required)",
          "otp": "string (Required: 6 digits)",
          "newPassword": "string (Required: Min 8 chars)"
        }
      },
      {
        "action": "Create Staff/Employee",
        "method": "POST",
        "url": "/auth/staff/create",
        "description": "Creates a new employee/staff member for a branch.",
        "body_schema": {
          "fullName": "string (Required, ex: Omar Yasser)",
          "username": "string (Required, ex: omar_admin_01)",
          "email": "string (Required, ex: omar.staff@example.com)",
          "password": "string (Required: Min 6 chars)",
          "role": "enum (Required: StaffRole - ADMIN, etc.)",
          "image": "string (Optional: URL)",
          "branchId": "number (Required, ex: 1)"
        },
        "security": "JwtAuthGuard (likely BUSINESS_OWNER)"
      },
      {
        "action": "Get Employee Profile",
        "method": "GET",
        "url": "/auth/employee/me",
        "description": "Returns the authenticated employee's profile.",
        "security": "JwtAuthGuard"
      }
    ]
  },
  {
    "service": "svc-restaurant",
    "base_url": "/restaurants",
    "endpoints": [
      {
        "action": "Get All Restaurants",
        "method": "GET",
        "url": "/restaurants",
        "description": "Retrieves a list of all restaurants.",
        "security": "JwtAuthGuard, RolesGuard (BUSINESS_OWNER)"
      },
      {
        "action": "Create Restaurant",
        "method": "POST",
        "url": "/restaurants",
        "description": "Creates a new restaurant associated with the authenticated user ID.",
        "body_schema": {
          "name": "string (Required, ex: Koshary El Tahrir)",
          "logoUrl": "string (Optional URL, ex: https://example.com/logo.png)"
        },
        "security": "JwtAuthGuard, RolesGuard (BUSINESS_OWNER)"
      },
      {
        "action": "Get Restaurant By ID",
        "method": "GET",
        "url": "/restaurants/:id",
        "description": "Fetches detailed information for a specific restaurant by its ID.",
        "params": {
          "id": "number (Required)"
        }
      },
      {
        "action": "Get Restaurants By Owner",
        "method": "GET",
        "url": "/restaurants/owner/:userId",
        "description": "Retrieves all restaurants belonging to a specific owner ID.",
        "params": {
          "userId": "number (Required)"
        }
      },
      {
        "action": "Update Restaurant",
        "method": "PATCH",
        "url": "/restaurants/update/:id",
        "description": "Updates details of an existing restaurant (partial updates).",
        "params": {
          "id": "number (Required)"
        },
        "body_schema": {
          "name": "string (Optional)",
          "logoUrl": "string (Optional)"
        }
      },
      {
        "action": "Delete Restaurant",
        "method": "DELETE",
        "url": "/restaurants/delete/:id",
        "description": "Removes a restaurant record from the database.",
        "params": {
          "id": "number (Required)"
        }
      }
    ]
  },
  {
    "service": "svc-branch",
    "base_url": "/branches",
    "endpoints": [
      {
        "action": "Create Branch",
        "method": "POST",
        "url": "/branches/:restaurantId",
        "description": "Adds a new branch to a restaurant.",
        "params": {
          "restaurantId": "number (Required)"
        },
        "body_schema": {
          "branchNumber": "number (Required, ex: 1)",
          "name": "string (Required, ex: Nasr City Branch)",
          "address": "string (Required, ex: 123 Abbas El Akkad St)",
          "restaurantId": "number (Required)",
          "haveTables": "boolean (Optional)",
          "tablesCount": "number (Optional, ex: 20)",
          "haveReservations": "boolean (Optional)",
          "haveWarehouses": "boolean (Optional)",
          "warehouseName": "string (Optional, ex: Main Warehouse)"
        }
      },
      {
        "action": "Get Branches by Restaurant",
        "method": "GET",
        "url": "/branches/:restaurantId",
        "params": {
          "restaurantId": "number (Required)"
        }
      },
      {
        "action": "Get Branch By ID",
        "method": "GET",
        "url": "/branches/:restaurantId/:branchId",
        "params": {
          "restaurantId": "number (Required)",
          "branchId": "number (Required)"
        }
      },
      {
        "action": "Update Branch",
        "method": "PATCH",
        "url": "/branches/:restaurantId/:branchId",
        "params": {
          "restaurantId": "number",
          "branchId": "number"
        },
        "body_schema": "Partial CreateBranchDto fields"
      },
      {
        "action": "Delete Branch",
        "method": "DELETE",
        "url": "/branches/:restaurantId/:branchId",
        "params": {
          "restaurantId": "number",
          "branchId": "number"
        }
      },
      {
        "action": "Get Branch Menu",
        "method": "GET",
        "url": "/branches/:restaurantId/:branchId/menu",
        "params": {
          "restaurantId": "number",
          "branchId": "number"
        }
      },
      {
        "action": "Create Menu Item",
        "method": "POST",
        "url": "/branches/:restaurantId/:branchId/menu",
        "params": {
          "restaurantId": "number",
          "branchId": "number"
        },
        "body_schema": {
          "menuItemId": "number",
          "branchId": "number",
          "name": "string (ex: Chicken Shawarma)",
          "description": "string (opt)",
          "image": "string (opt URL)",
          "isAvailable": "boolean",
          "variations": "array of {id: num, name: str, price: num}",
          "dietaryTags": "array of numbers (opt)",
          "recipe": "array of {ingredientId: num, quantityRequired: num, unit: str}"
        }
      },
      {
        "action": "Upload Menu Excel",
        "method": "POST",
        "url": "/branches/:restaurantId/:branchId/menu/upload",
        "description": "Upload Excel file to bulk create/update menu items.",
        "params": {
          "restaurantId": "number",
          "branchId": "number"
        },
        "body": "multipart/form-data, field 'file' (Excel file)"
      },
      {
        "action": "Update Menu Item",
        "method": "PATCH",
        "url": "/branches/:restaurantId/:branchId/menu/:menuItemId",
        "params": {
          "restaurantId": "number",
          "branchId": "number",
          "menuItemId": "number"
        },
        "body_schema": "Partial BranchMenuItemDetailDto"
      },
      {
        "action": "Delete Menu Item",
        "method": "DELETE",
        "url": "/branches/:restaurantId/:branchId/menu/:menuItemId",
        "params": {
          "restaurantId": "number",
          "branchId": "number",
          "menuItemId": "number"
        }
      },
      {
        "action": "Create Order",
        "method": "POST",
        "url": "/branches/:restaurantId/:branchId/orders",
        "params": {
          "restaurantId": "number",
          "branchId": "number"
        },
        "body_schema": {
          "totalAmount": "number (ex: 150.75)",
          "branchId": "number",
          "userId": "number",
          "status": "OrderState enum (opt, ex: PENDING)"
        }
      },
      {
        "action": "Get Orders by Branch",
        "method": "GET",
        "url": "/branches/:restaurantId/:branchId/orders",
        "params": {
          "restaurantId": "number",
          "branchId": "number"
        }
      },
      {
        "action": "Get Order by ID",
        "method": "GET",
        "url": "/branches/:restaurantId/:branchId/orders/:orderId",
        "params": {
          "orderId": "number"
        }
      },
      {
        "action": "Update Order",
        "method": "PATCH",
        "url": "/branches/:restaurantId/:branchId/orders/:orderId",
        "params": {
          "orderId": "number"
        },
        "body_schema": "Partial CreateOrderDto"
      },
      {
        "action": "Delete Order",
        "method": "DELETE",
        "url": "/branches/:restaurantId/:branchId/orders/:orderId",
        "params": {
          "orderId": "number"
        }
      }
    ]
  },
  {
    "service": "real-time-events",
    "protocol": "WebSocket (Socket.io)",
    "connection_url": "ws://localhost:9000",
    "description": "Live Feed for real-time updates via branch.gateway.ts.",
    "events": [
      {
        "event": "new_branch_added",
        "trigger": "Create Branch successful",
        "data_payload": "Complete Branch Object",
        "ui_action": "Append to list"
      },
      {
        "event": "branch_updated",
        "trigger": "Update Branch successful",
        "data_payload": "Updated Branch Object",
        "ui_action": "Replace by ID"
      },
      {
        "event": "branch_deleted",
        "trigger": "Delete Branch successful",
        "data_payload": "{ id: number, restaurantId: number }",
        "ui_action": "Remove by ID"
      },
      {
        "event": "menu_item_updated",
        "trigger": "Update Menu Item successful",
        "data_payload": "Updated Menu Item Object",
        "ui_action": "Replace menu item in list"
      },
      {
        "event": "menu_item_deleted",
        "trigger": "Delete Menu Item successful",
        "data_payload": "{ id: number }",
        "ui_action": "Remove menu item from list"
      },
      {
        "event": "new_order_added",
        "trigger": "Create Order successful",
        "data_payload": "New Order Object",
        "ui_action": "Append to orders list"
      },
      {
        "event": "order_updated",
        "trigger": "Update Order successful",
        "data_payload": "Updated Order Object",
        "ui_action": "Replace order in list"
      },
      {
        "event": "order_deleted",
        "trigger": "Delete Order successful",
        "data_payload": "{ id: number }",
        "ui_action": "Remove order from list"
      }
    ]
  }
]

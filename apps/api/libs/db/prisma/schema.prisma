generator client {
  provider     = "prisma-client"
  output       = "../generated/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model SystemAdmin {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  fullName     String
  image        String?
  role         UserRole      @default(CUSTOMER)
  phone        String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  otpCode      String?
  otpExpires   DateTime?
  username     String        @unique
  salary       Decimal?      @db.Decimal(10, 2)
  branchId    Int?
  branch       Branch?       @relation(fields: [branchId], references: [id])
  orders       Order[]
  reservations Reservation[]
  restaurants  Restaurant[]
  shifts       Shift[]
}

model TokenBlacklist {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  createdAt DateTime @default(now())
}

model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  logoUrl   String?
  ownerId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
  user      User     @relation(fields: [ownerId], references: [id])
}

model Branch {
  id               Int              @id @default(autoincrement())
  branchNumber     String
  name             String
  address          String           @unique
  restaurantId     Int
  haveTables       Boolean          @default(false)
  haveReservations Boolean          @default(false)
  haveWarehouses   Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  restaurant       Restaurant       @relation(fields: [restaurantId], references: [id])
  branchMenu       BranchMenuItem[]
  employees        User[]
  expenses         Expense[]
  orders           Order[]
  reservations     Reservation[]
  shifts           Shift[]
  tables           Table[]
  warehouses       Warehouse[]
}
model Shift {
  id         Int         @id @default(autoincrement())
  userId     Int
  branchId   Int
  startTime  DateTime    @default(now())
  endTime    DateTime?
  status     ShiftStatus @default(ACTIVE)
  branch     Branch      @relation(fields: [branchId], references: [id])
  employee   User        @relation(fields: [userId], references: [id])
}

model BranchMenuItem {
  id          Int                 @id @default(autoincrement())
  branchId    Int
  menuItemId  Int
  isAvailable Boolean             @default(true)
  name        String
  description String?
  image       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  branch      Branch              @relation(fields: [branchId], references: [id])
  variations  MenuItemVariation[]
  orders      OrderItem[]
  recipe      Recipe[]
  dietaryTags DietaryTag[]        @relation("BranchMenuItemToDietaryTag")
}

model MenuItemVariation {
  id               Int            @id @default(autoincrement())
  size             String
  price            Decimal        @db.Decimal(10, 2)
  discountPrice    Decimal?       @db.Decimal(10, 2)
  branchMenuItemId Int
  branchMenuItem   BranchMenuItem @relation(fields: [branchMenuItemId], references: [id], onDelete: Cascade)
}

model DietaryTag {
  id              Int              @id @default(autoincrement())
  name            DietaryType
  branchMenuItems BranchMenuItem[] @relation("BranchMenuItemToDietaryTag")
}

model Ingredient {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  unit           String
  inventoryItems InventoryItem[]
  recipes        Recipe[]
}

model Recipe {
  id               Int            @id @default(autoincrement())
  menuItemId       Int
  ingredientId     Int
  quantityRequired Float
  ingredient       Ingredient     @relation(fields: [ingredientId], references: [id])
  menuItem         BranchMenuItem @relation(fields: [menuItemId], references: [id])
}

model Warehouse {
  id       Int             @id @default(autoincrement())
  name     String
  branchId Int
  items    InventoryItem[]
  branch   Branch          @relation(fields: [branchId], references: [id])
}

model InventoryItem {
  id           Int        @id @default(autoincrement())
  ingredientId Int
  quantity     Float
  warehouseId  Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id])
}

model Order {
  id          Int         @id @default(autoincrement())
  totalAmount Decimal     @db.Decimal(10, 2)
  branchId    Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userId      Int
  status      OrderState  @default(PENDING)
  branch      Branch      @relation(fields: [branchId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id             Int            @id @default(autoincrement())
  orderId        Int
  menuItemId     Int
  quantity       Int
  price          Decimal        @db.Decimal(10, 2)
  branchMenuItem BranchMenuItem @relation(fields: [menuItemId], references: [id])
  order          Order          @relation(fields: [orderId], references: [id])
}

model Table {
  id           Int           @id @default(autoincrement())
  tableNumber  String
  capacity     Int
  branchId     Int
  reservations Reservation[]
  branch       Branch        @relation(fields: [branchId], references: [id])

  @@unique([tableNumber, branchId])
}

model Reservation {
  id              Int      @id @default(autoincrement())
  reservationTime DateTime
  depositAmount   Decimal  @db.Decimal(10, 2)
  isPaid          Boolean  @default(false)
  tableId         Int
  branchId        Int
  createdAt       DateTime @default(now())
  userId          Int
  branch          Branch   @relation(fields: [branchId], references: [id])
  table           Table    @relation(fields: [tableId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model Expense {
  id          Int         @id @default(autoincrement())
  amount      Decimal     @db.Decimal(10, 2)
  category    ExpenseType
  description String?
  branchId    Int
  createdAt   DateTime    @default(now())
  branch      Branch      @relation(fields: [branchId], references: [id])
}

enum UserRole {
  CUSTOMER
  BUSINESS_OWNER
  CHIEF
  WAITER
  MANAGER
  CASHIER
}

enum ShiftStatus {
  ACTIVE
  WORKING
  COMPLETED
}

enum OrderState {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DietaryType {
  VEGAN
  GLUTEN_FREE
  DAIRY_FREE
}

enum ExpenseType {
  INGREDIENTS
  SALARY
  RENT
  UTILITIES
  LOSSES
  MARKETING
}

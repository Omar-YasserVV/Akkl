generator client {
  provider     = "prisma-client"
  output       = "../generated/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model SystemAdmin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  fullName     String
  image        String?
  role         UserRole      @default(CUSTOMER)
  phone        String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  otpCode      String?
  otpExpires   DateTime?
  username     String        @unique
  salary       Decimal?      @db.Decimal(10, 2)
  branchId     String?
  branch       Branch?       @relation(fields: [branchId], references: [id])
  orders       Order[]
  reservations Reservation[]
  restaurants  Restaurant[]
  shifts       Shift[]
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
}

model Restaurant {
  id        String   @id @default(uuid())
  name      String   @unique
  logoUrl   String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
  user      User     @relation(fields: [ownerId], references: [id])
}

model Branch {
  id               String           @id @default(uuid())
  branchNumber     String
  name             String
  address          String           @unique
  restaurantId     String
  haveTables       Boolean          @default(false)
  haveReservations Boolean          @default(false)
  haveWarehouses   Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  restaurant       Restaurant       @relation(fields: [restaurantId], references: [id])
  branchMenu       BranchMenuItem[]
  employees        User[]
  expenses         Expense[]
  orders           Order[]
  reservations     Reservation[]
  shifts           Shift[]
  tables           Table[]
  warehouses       Warehouse[]
}

model Shift {
  id        String      @id @default(uuid())
  userId    String
  branchId  String
  startTime DateTime    @default(now())
  endTime   DateTime?
  status    ShiftStatus @default(ACTIVE)
  branch    Branch      @relation(fields: [branchId], references: [id])
  employee  User        @relation(fields: [userId], references: [id])
}

model BranchMenuItem {
  id          String              @id @default(uuid())
  branchId    String
  menuItemId  String
  isAvailable Boolean             @default(true)
  name        String
  description String?
  image       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  branch      Branch              @relation(fields: [branchId], references: [id])
  variations  MenuItemVariation[]
  orders      OrderItem[]
  recipe      Recipe[]
  dietaryTags DietaryTag[]        @relation("BranchMenuItemToDietaryTag")
}

model MenuItemVariation {
  id               String         @id @default(uuid())
  size             String
  price            Decimal        @db.Decimal(10, 2)
  discountPrice    Decimal?       @db.Decimal(10, 2)
  branchMenuItemId String
  branchMenuItem   BranchMenuItem @relation(fields: [branchMenuItemId], references: [id], onDelete: Cascade)
}

model DietaryTag {
  id              String           @id @default(uuid())
  name            DietaryType
  branchMenuItems BranchMenuItem[] @relation("BranchMenuItemToDietaryTag")
}

model Ingredient {
  id             String          @id @default(uuid())
  name           String          @unique
  unit           String
  inventoryItems InventoryItem[]
  recipes        Recipe[]
}

model Recipe {
  id               String         @id @default(uuid())
  menuItemId       String
  ingredientId     String
  quantityRequired Float
  ingredient       Ingredient     @relation(fields: [ingredientId], references: [id])
  menuItem         BranchMenuItem @relation(fields: [menuItemId], references: [id])
}

model Warehouse {
  id       String          @id @default(uuid())
  name     String
  branchId String          @unique
  items    InventoryItem[]
  branch   Branch          @relation(fields: [branchId], references: [id])
}

model InventoryItem {
  id           String     @id @default(uuid())
  ingredientId String
  quantity     Float
  stockStatus  stockStatus @default(IN_STOCK)
  minimumQuantity Float @default(0)
  warehouseId  String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id])
}

model Order {
  id           String      @id @default(uuid())
  totalPrice   Decimal     @db.Decimal(10, 2)
  branchId     String
  userId       String
  CustomerName String
  source       source      @default(STORE)
  itemCount    Int
  status       OrderState  @default(PENDING)
  specialInstructions String? 
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  branch       Branch      @relation(fields: [branchId], references: [id])
  user         User        @relation(fields: [userId], references: [id])
  items        OrderItem[]
}

model OrderItem {
  id             String         @id @default(uuid())
  orderId        String
  menuItemId     String
  quantity       Int
  price          Decimal        @db.Decimal(10, 2)
  branchMenuItem BranchMenuItem @relation(fields: [menuItemId], references: [id])
  order          Order          @relation(fields: [orderId], references: [id])
}

model Table {
  id           String        @id @default(uuid())
  tableNumber  String
  capacity     Int
  branchId     String
  reservations Reservation[]
  branch       Branch        @relation(fields: [branchId], references: [id])

  @@unique([tableNumber, branchId])
}

model Reservation {
  id              String   @id @default(uuid())
  reservationTime DateTime
  depositAmount   Decimal  @db.Decimal(10, 2)
  isPaid          Boolean  @default(false)
  tableId         String
  branchId        String
  createdAt       DateTime @default(now())
  userId          String
  branch          Branch   @relation(fields: [branchId], references: [id])
  table           Table    @relation(fields: [tableId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model Expense {
  id          String      @id @default(uuid())
  amount      Decimal     @db.Decimal(10, 2)
  category    ExpenseType
  description String?
  branchId    String
  createdAt   DateTime    @default(now())
  branch      Branch      @relation(fields: [branchId], references: [id])
}

enum UserRole {
  CUSTOMER
  BUSINESS_OWNER
  CHIEF
  WAITER
  MANAGER
  CASHIER
}

enum ShiftStatus {
  ACTIVE
  WORKING
  COMPLETED
}

enum OrderState {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DietaryType {
  VEGAN
  GLUTEN_FREE
  DAIRY_FREE
}

enum source {
  APP
  STORE
}

enum ExpenseType {
  INGREDIENTS
  SALARY
  RENT
  UTILITIES
  LOSSES
  MARKETING
}

enum stockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}
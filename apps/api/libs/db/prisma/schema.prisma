generator client {
  provider     = "prisma-client"
  output       = "../generated/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// Represents a system administrator account.
model SystemAdmin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
}

/// Represents an application user (Customers and Staff).
model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  fullName     String
  image        String?
  role         UserRole      @default(CUSTOMER)
  phone        String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  otpCode      String?
  otpExpires   DateTime?
  username     String        @unique
  salary       Decimal?      @db.Decimal(10, 2)
  branchId     String?
  birthDate    DateTime?
  gender       Gender?
  orders       Order[]
  reservations Reservation[]
  restaurants  Restaurant[]
  shifts       Shift[]
  branch       Branch?       @relation(fields: [branchId], references: [id])
}

/// Stores tokens that should be blacklisted (e.g., for logout).
model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
}

/// Represents a restaurant brand owned by a Business Owner.
model Restaurant {
  id        String   @id @default(uuid())
  name      String   @unique
  logoUrl   String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
  user      User     @relation(fields: [ownerId], references: [id])
}

/// Represents a specific branch location of a restaurant.
model Branch {
  id               String              @id @default(uuid())
  status           BranchStatus        @default(DRAFT)
  branchNumber     String              @unique
  name             String
  address          String?
  latitude         Float?
  longitude        Float?
  phone            String?
  weeklyHours      Json?
  busyModeSettings Json?
  haveTables       Boolean             @default(false)
  haveReservations Boolean             @default(false)
  haveWarehouses   Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  restaurantId     String
  restaurant       Restaurant          @relation(fields: [restaurantId], references: [id])
  branchMenu       BranchMenuItem[]
  expenses         Expense[]
  hardware         Hardware[]
  inventoryLogs    InventoryUsageLog[] @relation("BranchInventoryUsageLogs")
  orders           Order[]
  reservations     Reservation[]
  shifts           Shift[]
  tables           Table[]
  employees        User[]
  warehouses       Warehouse?
}

/// Tracks device hardware connected to a branch (Step 4 wizard).
model Hardware {
  id        String       @id @default(uuid())
  branchId  String
  type      HardwareType
  name      String
  ipAddress String
  createdAt DateTime     @default(now())
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

/// Represents a work shift for an employee at a branch.
model Shift {
  id        String      @id @default(uuid())
  userId    String
  branchId  String
  startTime DateTime    @default(now())
  endTime   DateTime?
  status    ShiftStatus @default(ACTIVE)
  branch    Branch      @relation(fields: [branchId], references: [id])
  employee  User        @relation(fields: [userId], references: [id])
}

/// Represents a menu item available at a specific branch.
model BranchMenuItem {
  id              String              @id @default(uuid())
  branchId        String
  menuItemId      String
  category        MenuCategory        @default(MAIN_COURSE)
  price           Decimal             @db.Decimal(10, 2)
  discountPrice   Decimal?            @db.Decimal(10, 2)
  preparationTime Int
  isAvailable     Boolean             @default(true)
  name            String
  description     String?
  image           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  branch          Branch              @relation(fields: [branchId], references: [id])
  variations      MenuItemVariation[]
  orderItems      OrderItem[]
  recipe          Recipe[]
  dietaryTags     DietaryTag[]        @relation("BranchMenuItemToDietaryTag")
}

/// Represents a variation (e.g., size) of a menu item.
model MenuItemVariation {
  id               String         @id @default(uuid())
  size             String
  price            Decimal        @db.Decimal(10, 2)
  discountPrice    Decimal?       @db.Decimal(10, 2)
  branchMenuItemId String
  branchMenuItem   BranchMenuItem @relation(fields: [branchMenuItemId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
}

/// Dietary tag metadata for menu filtration.
model DietaryTag {
  id              String           @id @default(uuid())
  name            DietaryType
  branchMenuItems BranchMenuItem[] @relation("BranchMenuItemToDietaryTag")
}

/// Core global catalog definition of an ingredient resource.
model Ingredient {
  id             String             @id @default(uuid())
  name           String             @unique
  unit           MeasurementUnit
  category       IngredientCategory
  inventoryItems InventoryItem[]
  recipes        Recipe[]
}

/// Recipe step mapping item composition to stock consumption requirements.
model Recipe {
  id               String         @id @default(uuid())
  menuItemId       String
  ingredientId     String
  quantityRequired Float
  ingredient       Ingredient     @relation(fields: [ingredientId], references: [id])
  menuItem         BranchMenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([menuItemId, ingredientId])
}

/// Storage warehouse environment details bounded to a branch.
model Warehouse {
  id       String          @id @default(uuid())
  name     String
  branchId String          @unique
  items    InventoryItem[]
  branch   Branch          @relation(fields: [branchId], references: [id])
}

/// Live real-time current branch storage tracking metric ledger entries.
model InventoryItem {
  id              String              @id @default(uuid())
  ingredientId    String
  quantity        Float
  stockStatus     StockStatus         @default(OUT_OF_STOCK)
  minimumQuantity Float               @default(0)
  warehouseId     String
  ingredient      Ingredient          @relation(fields: [ingredientId], references: [id])
  warehouse       Warehouse           @relation(fields: [warehouseId], references: [id])
  usageLogs       InventoryUsageLog[]
  batches         StockBatch[]

  @@unique([ingredientId, warehouseId])
  @@index([warehouseId])
  @@index([ingredientId])
  @@index([stockStatus])
}

/// Batch entry mapping inventory tracing metrics (FIFO support tracking structure).
model StockBatch {
  id                String        @id @default(uuid())
  inventoryItemId   String
  initialQuantity   Float
  remainingQuantity Float
  numberOfUnits     Int?
  unitSize          Float?
  costPerUnit       Decimal?      @db.Decimal(10, 2)
  receivedAt        DateTime      @default(now())
  expiresAt         DateTime?
  status            BatchStatus   @default(ACTIVE)
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
}

/// Financial and volumetric structural logging tracing model ledger.
model InventoryUsageLog {
  id               String             @id @default(uuid())
  inventoryItemId  String
  action           InventoryLogAction
  quantityChange   Float              @default(0)
  previousQuantity Float
  newQuantity      Float
  notes            String?
  createdAt        DateTime           @default(now())
  orderId          String?
  branchId         String
  branch           Branch             @relation("BranchInventoryUsageLogs", fields: [branchId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem      @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  order            Order?             @relation("OrderInventoryUsageLog", fields: [orderId], references: [id])

  @@index([inventoryItemId])
  @@index([inventoryItemId, createdAt])
  @@index([action])
  @@index([createdAt])
}

/// Ticket core management system database structural design.
model Order {
  id                 String              @id @default(uuid())
  orderNumber        Int                 @unique @default(autoincrement())
  totalPrice         Decimal             @db.Decimal(10, 2)
  branchId           String
  userId             String
  customerName       String
  source             OrderSource         @default(STORE)
  itemCount          Int
  status             OrderState          @default(PENDING)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryUsageLogs InventoryUsageLog[] @relation("OrderInventoryUsageLog")
  branch             Branch              @relation(fields: [branchId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  items              OrderItem[]

  @@index([status])
  @@index([branchId])
  @@index([createdAt])
  @@index([branchId, status, createdAt])
}

/// Line item details relating individual ticket components to configurations.
model OrderItem {
  id                  String             @id @default(uuid())
  orderId             String
  menuItemId          String
  specialInstructions String?
  quantity            Int
  price               Decimal            @db.Decimal(10, 2)
  totalPrice          Decimal            @db.Decimal(10, 2)
  variationId         String?
  branchMenuItem      BranchMenuItem     @relation(fields: [menuItemId], references: [id])
  order               Order              @relation(fields: [orderId], references: [id])
  variation           MenuItemVariation? @relation(fields: [variationId], references: [id])

  @@index([menuItemId])
  @@index([orderId])
}

/// Layout mapping node reference model for floor operations tracking.
model Table {
  id           String        @id @default(uuid())
  tableNumber  String
  capacity     Int
  zoneName     String?
  branchId     String
  status       TableStatus   @default(AVAILABLE)
  reservations Reservation[]
  branch       Branch        @relation(fields: [branchId], references: [id])
}

/// Active seat preservation data tracking table configurations.
model Reservation {
  id                 String            @id @default(uuid())
  reservationTime    DateTime
  depositAmount      Decimal           @db.Decimal(10, 2)
  isPaid             Boolean           @default(false)
  tableId            String
  branchId           String
  createdAt          DateTime          @default(now())
  userId             String
  reservation_status ReservationStatus @default(ACTIVE)
  branch             Branch            @relation(fields: [branchId], references: [id])
  table              Table             @relation(fields: [tableId], references: [id])
  user               User              @relation(fields: [userId], references: [id])
}

/// Operational expenditure cost calculation records.
model Expense {
  id          String      @id @default(uuid())
  amount      Decimal     @db.Decimal(10, 2)
  category    ExpenseType
  description String?
  branchId    String
  createdAt   DateTime    @default(now())
  branch      Branch      @relation(fields: [branchId], references: [id])
}

enum ReservationStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum MenuCategory {
  APPETIZER
  MAIN_COURSE
  DESSERT
  BEVERAGE
  SIDE_DISH
  OTHER
}

enum UserRole {
  CUSTOMER
  BUSINESS_OWNER
  CHIEF
  WAITER
  MANAGER
  CASHIER
}

enum BranchStatus {
  DRAFT
  ACTIVE
}

enum HardwareType {
  KDS
  PRINTER
}

enum ShiftStatus {
  ACTIVE
  WORKING
  COMPLETED
}

enum OrderState {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TableStatus {
  AVAILABLE
  RESERVED
  SEATED
  DIRTY
}

enum DietaryType {
  VEGAN
  GLUTEN_FREE
  DAIRY_FREE
}

enum OrderSource {
  APP
  STORE
}

enum ExpenseType {
  INGREDIENTS
  SALARY
  RENT
  UTILITIES
  LOSSES
  MARKETING
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum BatchStatus {
  ACTIVE
  DEPLETED
  EXPIRED
  DAMAGED
}

enum InventoryLogAction {
  CREATE
  RESTOCK
  CONSUME
  UPDATE
}

enum MeasurementUnit {
  KG
  G
  L
  ML
  PCS
  TSP
  TBSP
  CUP
}

enum IngredientCategory {
  MEAT
  SEAFOOD
  DAIRY
  PRODUCE
  GRAINS
  SPICES
  OILS
  SAUCES
  BAKERY
  BEVERAGES
  NUTS
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

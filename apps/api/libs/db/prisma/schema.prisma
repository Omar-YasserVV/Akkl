/// Prisma client generator configuration.
/// Generates Prisma client code in CommonJS format.
generator client {
  provider     = "prisma-client"
  output       = "../generated/client"
  moduleFormat = "cjs"
}

/// Database datasource definition.
/// Uses PostgreSQL as the database provider.
datasource db {
  provider = "postgresql"
}

/// Represents a system administrator account.
model SystemAdmin {
  id        String    @id @default(uuid())   /// Primary key, UUID generated by default.
  email     String    @unique                /// Unique email address for the admin.
  password  String                          /// Hashed password.
  createdAt DateTime  @default(now())       /// Timestamp for creation.
  updatedAt DateTime  @updatedAt            /// Timestamp for last update.
  lastLogin DateTime?                       /// Timestamp for last login, optional.
}

/// Represents an application user.
model User {
  id           String        @id @default(uuid())   /// Primary key, UUID generated by default.
  email        String        @unique                /// Unique user email.
  password     String                                /// Hashed password.
  fullName     String                                /// User's full name.
  image        String?                               /// Optional profile image URL.
  role         UserRole      @default(CUSTOMER)      /// User's role, defaults to CUSTOMER.
  phone        String        @unique                 /// User's unique phone number.
  createdAt    DateTime      @default(now())         /// Timestamp for creation.
  updatedAt    DateTime      @updatedAt              /// Timestamp for last update.
  otpCode      String?                                /// One-time password for authentication.
  otpExpires   DateTime?                              /// Expiry for OTP code.
  username     String        @unique                 /// Unique username.
  salary       Decimal?      @db.Decimal(10, 2)      /// Optional salary.
  branchId     String?                                /// Optional reference to Branch.
  orders       Order[]                                 /// Orders placed by the user.
  reservations Reservation[]                           /// Reservations made by the user.
  restaurants  Restaurant[]                            /// Restaurants owned/associated.
  shifts       Shift[]                                 /// Shifts worked by the user.
  branch       Branch?        @relation(fields: [branchId], references: [id]) /// Associated branch.
}

/// Stores tokens that should be blacklisted (e.g., for logout).
model TokenBlacklist {
  id        String   @id @default(uuid())     /// Primary key, UUID generated by default.
  token     String   @unique                  /// Blacklisted token (JWT, etc).
  createdAt DateTime @default(now())          /// Timestamp for creation.
}

/// Represents a restaurant owned by a User.
model Restaurant {
  id        String   @id @default(uuid())     /// Primary key, UUID generated by default.
  name      String   @unique                  /// Unique restaurant name.
  logoUrl   String?                           /// Optional logo URL.
  ownerId   String                            /// Referenced user ID (owner).
  createdAt DateTime @default(now())          /// Timestamp for creation.
  updatedAt DateTime @updatedAt               /// Timestamp for last update.
  branches  Branch[]                          /// Branches under this restaurant.
  user      User     @relation(fields: [ownerId], references: [id]) /// Owner relation.
}

/// Represents a branch of a restaurant.
model Branch {
  id               String           @id @default(uuid())          /// Primary key, UUID generated by default.
  branchNumber     String                                         /// Unique branch number.
  name             String                                         /// Branch display name.
  address          String           @unique                       /// Unique branch address.
  restaurantId     String                                         /// Reference to parent restaurant.
  haveTables       Boolean          @default(false)                /// Whether branch has tables.
  haveReservations Boolean          @default(false)                /// Reservations enabled.
  haveWarehouses   Boolean          @default(false)                /// Warehouses enabled.
  createdAt        DateTime         @default(now())                /// Timestamp for creation.
  updatedAt        DateTime         @updatedAt                     /// Timestamp for last update.
  restaurant       Restaurant       @relation(fields: [restaurantId], references: [id]) /// Parent restaurant relation.
  branchMenu       BranchMenuItem[]                                /// Menu items at this branch.
  expenses         Expense[]                                       /// Expenses for the branch.
  orders           Order[]                                         /// Orders belonging to this branch.
  reservations     Reservation[]                                   /// Reservations at this branch.
  shifts           Shift[]                                         /// Shifts scheduled for the branch.
  tables           Table[]                                         /// Tables at the branch.
  employees        User[]                                          /// Employees assigned.
  warehouses       Warehouse?                                      /// Optional warehouse assigned to branch.
}

/// Represents a work shift for an employee at a branch.
model Shift {
  id        String      @id @default(uuid())                  /// Primary key, UUID generated by default.
  userId    String                                         /// Employee user ID.
  branchId  String                                         /// Branch reference.
  startTime DateTime    @default(now())                     /// Shift start time.
  endTime   DateTime?                                       /// Shift end time, optional.
  status    ShiftStatus @default(ACTIVE)                    /// Status of shift.
  branch    Branch      @relation(fields: [branchId], references: [id]) /// Relation to branch.
  employee  User        @relation(fields: [userId], references: [id])   /// Relation to employee (User).
}

/// Represents a menu item for a branch.
model BranchMenuItem {
  id              String              @id @default(uuid())                     /// Primary key.
  branchId        String                                                  /// Reference to Branch.
  menuItemId      String                                                  /// Unique menu item ID.
  category        category            @default(MAIN_COURSE)               /// Category of menu item.
  price           Decimal             @db.Decimal(10, 2)                  /// Price.
  discountPrice   Decimal?            @db.Decimal(10, 2)                  /// Optional discounted price.
  preparationTime Int                                                    /// Estimated prep time in minutes.
  isAvailable     Boolean             @default(true)                      /// Availability flag.
  name            String                                                  /// Name of menu item.
  description     String?                                                 /// Optional description.
  image           String?                                                 /// Optional image URL.
  createdAt       DateTime            @default(now())                     /// Timestamp for creation.
  updatedAt       DateTime            @updatedAt                          /// Timestamp for last update.
  branch          Branch              @relation(fields: [branchId], references: [id]) /// Branch relation.
  variations      MenuItemVariation[]                                     /// Variations (size, price, etc).
  orders          OrderItem[]                                            /// Orders including this item.
  recipe          Recipe[]                                               /// Recipe ingredients, etc.
  dietaryTags     DietaryTag[]        @relation("BranchMenuItemToDietaryTag") /// Dietary tags.
}

/// Represents a variation (e.g., size) of a branch's menu item.
model MenuItemVariation {
  id               String         @id @default(uuid())                       /// Primary key.
  size             String                                             /// Variation size/label.
  price            Decimal        @db.Decimal(10, 2)                  /// Price for this variation.
  discountPrice    Decimal?       @db.Decimal(10, 2)                  /// Optional discounted price.
  branchMenuItemId String                                            /// Reference to BranchMenuItem.
  branchMenuItem   BranchMenuItem @relation(fields: [branchMenuItemId], references: [id], onDelete: Cascade) /// Relation to menu item.
}

/// Dietary tag (e.g., VEGAN, GLUTEN_FREE) for menu items.
model DietaryTag {
  id              String           @id @default(uuid())                  /// Primary key.
  name            DietaryType                                 /// Type of dietary tag.
  branchMenuItems BranchMenuItem[] @relation("BranchMenuItemToDietaryTag") /// Linked menu items.
}

/// Represents an ingredient used in recipes or for stock.
model Ingredient {
  id             String             @id @default(uuid())            /// Primary key.
  name           String             @unique                        /// Ingredient name (unique).
  unit           MeasurementUnit                                  /// Measurement unit (e.g., KG).
  category       IngredientCategory                                /// Ingredient category (MEAT, etc).
  inventoryItems InventoryItem[]                                  /// Inventory records.
  recipes        Recipe[]                                         /// Recipes using this ingredient.
}

/// Recipe line: ingredient and amount for a menu item.
model Recipe {
  id               String         @id @default(uuid())                    /// Primary key.
  menuItemId       String                                      /// Reference to BranchMenuItem.
  ingredientId     String                                      /// Reference to Ingredient.
  quantityRequired Float                                        /// Amount required.
  ingredient       Ingredient     @relation(fields: [ingredientId], references: [id]) /// Linked ingredient.
  menuItem         BranchMenuItem @relation(fields: [menuItemId], references: [id])   /// Linked menu item.

  @@unique([menuItemId, ingredientId])                          /// Each (menuItem, ingredient) must be unique.
}

/// Warehouse assigned to a branch for ingredient storage.
model Warehouse {
  id       String          @id @default(uuid())              /// Primary key.
  name     String                                        /// Name of warehouse.
  branchId String          @unique                        /// Unique branch reference.
  items    InventoryItem[]                              /// Inventory items in this warehouse.
  branch   Branch          @relation(fields: [branchId], references: [id]) /// Owning branch.
}

/// Inventory item (ingredient + warehouse).
model InventoryItem {
  id              String              @id @default(uuid())             /// Primary key.
  ingredientId    String                                       /// Ingredient reference.
  quantity        Float                                         /// Current available stock.
  stockStatus     stockStatus         @default(OUT_OF_STOCK)   /// Stock status.
  minimumQuantity Float               @default(0)              /// Restock threshold.
  warehouseId     String                                       /// Reference to Warehouse.
  ingredient      Ingredient          @relation(fields: [ingredientId], references: [id]) /// Ingredient relation.
  warehouse       Warehouse           @relation(fields: [warehouseId], references: [id])  /// Warehouse relation.
  usageLogs       InventoryUsageLog[]                           /// Usage, change, restock logs.
  batches         StockBatch[]                                  /// Batches received for this item.

  @@unique([ingredientId, warehouseId])                         /// One entry per (ingredient, warehouse).
  @@index([warehouseId])                                        /// Index for querying by warehouse.
  @@index([ingredientId])                                       /// Index for ingredient-based search.
  @@index([stockStatus])                                        /// Index on stock status.
}

/// Batch of inventory received, with expiry, units, and costing.
model StockBatch {
  id                String        @id @default(uuid())                    /// Primary key.
  inventoryItemId   String                                    /// Inventory item reference.
  initialQuantity   Float                                     /// Amount received.
  remainingQuantity Float                                     /// Unused quantity.
  numberOfUnits     Int?                                      /// Number of packages, optional.
  unitSize          Float?                                    /// Size per package/unit.
  costPerUnit       Decimal?      @db.Decimal(10, 2)          /// Optional cost per unit.
  receivedAt        DateTime      @default(now())             /// When received.
  expiresAt         DateTime?                                 /// Optional batch expiry.
  status            BatchStatus   @default(ACTIVE)            /// Active/depleted/expired/damaged.
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade) /// Parent inventory item.
}

/// Track usage changes for inventory items (consumption, restocking, etc).
model InventoryUsageLog {
  id               String             @id @default(uuid())        /// Primary key.
  inventoryItemId  String                                    /// Reference to InventoryItem.
  action           InventoryLogAction                        /// CREATE, CONSUME, etc.
  quantityChange   Float              @default(0)            /// Quantity increase/decrease.
  previousQuantity Float                                     /// Stock before action.
  newQuantity      Float                                     /// Stock after action.
  notes            String?                                   /// Optional note.
  createdAt        DateTime           @default(now())        /// When the log was created.
  inventoryItem    InventoryItem      @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade) /// Inventory item relation.

  @@index([inventoryItemId])                                 /// Indexes for quick queries.
  @@index([inventoryItemId, createdAt])
  @@index([action])
  @@index([createdAt])
}

/// Customer order, associated with a branch and user.
model Order {
  id                  String      @id @default(uuid())             /// Primary key.
  orderNumber         Int         @unique @default(autoincrement())/// Public order number.
  totalPrice          Decimal     @db.Decimal(10, 2)               /// Total price.
  branchId            String                                     /// Reference to Branch.
  userId              String                                     /// Reference to User.
  CustomerName        String                                     /// Customer display name.
  source              source      @default(STORE)                 /// Origin (app, store).
  itemCount           Int                                         /// Number of items.
  status              OrderState  @default(PENDING)               /// Status of the order.
  specialInstructions String?                                    /// Special instructions for preparation.
  createdAt           DateTime    @default(now())                 /// When created.
  updatedAt           DateTime    @updatedAt                      /// Last update.
  branch              Branch      @relation(fields: [branchId], references: [id]) /// Branch relation.
  user                User        @relation(fields: [userId], references: [id])   /// Customer relation.
  items               OrderItem[]                                 /// Ordered items.
}

/// Item within an order (i.e., line item).
model OrderItem {
  id             String         @id @default(uuid())         /// Primary key.
  orderId        String                                 /// Reference to Order.
  menuItemId     String                                 /// Reference to BranchMenuItem.
  quantity       Int                                    /// Number of units ordered.
  price          Decimal        @db.Decimal(10, 2)       /// Unit price.
  branchMenuItem BranchMenuItem @relation(fields: [menuItemId], references: [id]) /// Menu item relation.
  order          Order          @relation(fields: [orderId], references: [id])    /// Order relation.
}

/// Table at a restaurant branch.
model Table {
  id           String        @id @default(uuid())            /// Primary key.
  tableNumber  String                                    /// Table number or identifier.
  capacity     Int                                       /// Number of seats.
  branchId     String                                    /// Reference to Branch.
  reservations Reservation[]                             /// Reservations for this table.
  branch       Branch        @relation(fields: [branchId], references: [id]) /// Branch relation.

  @@unique([tableNumber, branchId])                      /// Unique per branch.
}

/// Reservation for a table at a specific time.
model Reservation {
  id              String   @id @default(uuid())             /// Primary key.
  reservationTime DateTime                            /// Reservation timestamp.
  depositAmount   Decimal  @db.Decimal(10, 2)         /// Amount deposited (if any).
  isPaid          Boolean  @default(false)             /// Whether paid.
  tableId         String                             /// Reserved table.
  branchId        String                             /// Branch reference.
  createdAt       DateTime @default(now())           /// Created at.
  userId          String                             /// Reference to User.
  branch          Branch   @relation(fields: [branchId], references: [id]) /// Branch relation.
  table           Table    @relation(fields: [tableId], references: [id])  /// Table relation.
  user            User     @relation(fields: [userId], references: [id])   /// Reserving user.
}

/// Expense paid by a branch (e.g., supplies, salaries).
model Expense {
  id          String      @id @default(uuid())         /// Primary key.
  amount      Decimal     @db.Decimal(10, 2)       /// Expense amount.
  category    ExpenseType                        /// Type of expense.
  description String?                            /// Optional description.
  branchId    String                            /// Reference to Branch.
  createdAt   DateTime    @default(now())        /// Timestamp for creation.
  branch      Branch      @relation(fields: [branchId], references: [id]) /// Parent branch.
}

/// Food/menu category for menu items.
enum category {
  APPETIZER
  MAIN_COURSE
  DESSERT
  BEVERAGE
  SIDE_DISH
  OTHER
}

/// User roles in the application.
enum UserRole {
  CUSTOMER
  BUSINESS_OWNER
  CHIEF
  WAITER
  MANAGER
  CASHIER
}

/// Status for staff work shifts.
enum ShiftStatus {
  ACTIVE
  WORKING
  COMPLETED
}

/// Possible statuses for an order.
enum OrderState {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Dietary tag type for menu items.
enum DietaryType {
  VEGAN
  GLUTEN_FREE
  DAIRY_FREE
}

/// Source/origin of an order.
enum source {
  APP
  STORE
}

/// Types of expenses tracked in the system.
enum ExpenseType {
  INGREDIENTS
  SALARY
  RENT
  UTILITIES
  LOSSES
  MARKETING
}

/// Inventory stock status.
enum stockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

/// Status of an inventory batch.
enum BatchStatus {
  ACTIVE
  DEPLETED
  EXPIRED
  DAMAGED
}

/// Supported measurement units for inventory items and ingredients.
enum MeasurementUnit {
  KG      /// Kilogram: 1,000 grams.
  G       /// Gram: base unit of mass.
  L       /// Liter: base unit of volume.
  ML      /// Milliliter: 1/1,000th of a liter.
  PCS     /// Pieces: countable items.
  TSP     /// Teaspoon: small volume measure.
  TBSP    /// Tablespoon: 3 teaspoons.
  CUP     /// Cup: standard volume measure (approx. 240ml).
}

/// Types of ingredient categories.
enum IngredientCategory {
  MEAT
  SEAFOOD
  DAIRY
  PRODUCE
  GRAINS
  SPICES
  OILS
  SAUCES
  BAKERY
  BEVERAGES
  NUTS
  OTHER
}

/// How inventory was changed.
enum InventoryLogAction {
  CREATE    /// Initial inventory entry created.
  RESTOCK   /// Inventory restocked.
  CONSUME   /// Consumed for orders/recipes.
  UPDATE    /// Manual update/correction.
}
